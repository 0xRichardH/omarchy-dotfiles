#!/usr/bin/env bash

set -euo pipefail

engram_dir="${ENGRAM_DIR:-$HOME/.engram}"

if [[ ! -d "$engram_dir" ]]; then
  echo "Engram directory not found: $engram_dir" >&2
  exit 1
fi

cd "$engram_dir"

if [[ "${1:-}" == "--status" ]]; then
  exec engram sync --status
fi

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Engram directory is not a git repository: $engram_dir" >&2
  exit 1
fi

engram sync "$@"

git add -f .engram/

if git diff --cached --quiet -- .engram/; then
  echo "No new Engram sync chunks to commit."
  exit 0
fi

git commit -m "chore(engram): sync memories"
